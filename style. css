/* =========================
   Deepak Bhai Shop
   Style Part 1
========================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#f5f5f5;
    color:#222;
    padding-bottom:90px;
}

/* Header */

.header{
    background:#ffffff;
    position:sticky;
    top:0;
    z-index:1000;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.top-bar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:12px 15px;
}

.menu-btn{
    border:none;
    background:none;
    font-size:22px;
    cursor:pointer;
}

.logo h2{
    font-size:20px;
    color:#7b1fa2;
    font-weight:700;
}

.top-icons{
    display:flex;
    gap:18px;
    font-size:22px;
}

.top-icons i{
    cursor:pointer;
}

/* Search */

.search-box{
    padding:10px 15px 15px;
}

.search{
    display:flex;
    align-items:center;
    background:#f2f2f2;
    border-radius:12px;
    padding:12px;
}

.search input{
    flex:1;
    border:none;
    outline:none;
    background:none;
    font-size:15px;
    padding:0 10px;
}

.search i{
    color:#666;
    font-size:18px;
}

/* Refer Box */

.refer-box{
    padding:12px;
}

.refer{
    background:linear-gradient(90deg,#9c27b0,#e91e63);
    color:#fff;
    padding:15px;
    text-align:center;
    border-radius:12px;
    font-size:17px;
    font-weight:600;
}

/* Banner */

.banner-slider{
    padding:12px;
}

.slider{
    overflow:hidden;
    border-radius:15px;
}

.slider img{
    width:100%;
    display:block;
    border-radius:15px;
}
/* =========================
   Categories
========================= */

.categories{
    display:flex;
    overflow-x:auto;
    gap:12px;
    padding:12px;
    scrollbar-width:none;
}

.categories::-webkit-scrollbar{
    display:none;
}

.category{
    min-width:80px;
    background:#fff;
    border-radius:12px;
    text-align:center;
    padding:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
    cursor:pointer;
    transition:.3s;
}

.category:hover{
    transform:translateY(-3px);
}

.cat-icon{
    width:55px;
    height:55px;
    margin:auto;
    border-radius:50%;
    background:#f3e5f5;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:26px;
}

.category p{
    margin-top:8px;
    font-size:13px;
    font-weight:600;
}

/* =========================
   Section Title
========================= */

.title{
    padding:10px 15px;
}

.title h3{
    font-size:20px;
    font-weight:700;
}

/* =========================
   Products
========================= */

.products{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:14px;
    padding:12px;
}

.product-card{
    background:#fff;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 3px 10px rgba(0,0,0,.08);
    position:relative;
    transition:.3s;
}

.product-card:hover{
    transform:translateY(-4px);
}

.product-card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.wishlist{
    position:absolute;
    top:10px;
    right:10px;
    width:34px;
    height:34px;
    background:#fff;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    box-shadow:0 2px 8px rgba(0,0,0,.2);
    cursor:pointer;
}

.product-card h4{
    padding:10px;
    font-size:15px;
    height:45px;
    overflow:hidden;
}

.price{
    padding:0 10px;
}

.new-price{
    color:#7b1fa2;
    font-size:18px;
    font-weight:700;
}

.old-price{
    text-decoration:line-through;
    color:#888;
    margin-left:6px;
    font-size:13px;
}

.off{
    color:green;
    margin-left:6px;
    font-size:13px;
    font-weight:600;
}

.rating{
    padding:8px 10px;
    color:#ff9800;
    font-size:14px;
}

.buttons{
    display:flex;
    gap:8px;
    padding:10px;
}

.cart-btn,
.order-btn{
    flex:1;
    border:none;
    padding:10px;
    border-radius:8px;
    font-weight:600;
    cursor:pointer;
    transition:.3s;
}

.cart-btn{
    background:#eeeeee;
}

.cart-btn:hover{
    background:#dddddd;
}

.order-btn{
    background:#7b1fa2;
    color:#fff;
}

.order-btn:hover{
    background:#6a1b9a;
}
/* =========================
   Order Popup
========================= */

.order-popup{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,.55);
    display:none;
    justify-content:center;
    align-items:center;
    z-index:9999;
}

.popup-box{
    width:90%;
    max-width:350px;
    background:#fff;
    border-radius:20px;
    padding:25px;
    text-align:center;
    animation:popup .3s ease;
}

@keyframes popup{
    from{
        transform:scale(.8);
        opacity:0;
    }
    to{
        transform:scale(1);
        opacity:1;
    }
}

.popup-icon{
    font-size:55px;
    margin-bottom:10px;
}

.popup-box h2{
    color:#7b1fa2;
    margin-bottom:10px;
}

.popup-box p{
    color:#666;
    line-height:1.6;
    font-size:14px;
}

.popup-box button{
    margin-top:18px;
    width:100%;
    border:none;
    background:#7b1fa2;
    color:#fff;
    padding:12px;
    border-radius:10px;
    font-size:16px;
    font-weight:600;
    cursor:pointer;
}

/* =========================
   Bottom Navigation
========================= */

.bottom-nav{
    position:fixed;
    left:0;
    right:0;
    bottom:0;
    height:65px;
    background:#fff;
    display:flex;
    justify-content:space-around;
    align-items:center;
    box-shadow:0 -2px 12px rgba(0,0,0,.12);
    z-index:999;
}

.bottom-nav a{
    text-decoration:none;
    color:#666;
    display:flex;
    flex-direction:column;
    align-items:center;
    font-size:12px;
}

.bottom-nav i{
    font-size:22px;
    margin-bottom:4px;
}

.bottom-nav .active{
    color:#7b1fa2;
    font-weight:600;
}

/* =========================
   Mobile Responsive
========================= */

@media(max-width:480px){

.logo h2{
    font-size:18px;
}

.products{
    grid-template-columns:repeat(2,1fr);
    gap:10px;
}

.product-card img{
    height:160px;
}

.search input{
    font-size:14px;
}

}

/* Smooth Scroll */

html{
    scroll-behavior:smooth;
}
