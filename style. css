body {margin:0; font-family:Arial; background:#f8f8f8; padding-bottom:70px;}
.topbar {display:flex; justify-content:space-between; padding:10px; background:white; align-items:center;}
.profile {border-radius:50%;}
.refer {background:#f3e5f5; color:#8e24aa; padding:5px 10px; border-radius:20px; font-size:12px; margin-left:5px;}
.right span {font-size:22px; margin-left:15px; position:relative;}
.right sup {background:purple; color:white; border-radius:50%; padding:1px 5px; font-size:10px; position:absolute; top:-5px; right:-8px;}
.searchbar {background:white; margin:10px; padding:10px; border-radius:10px; border:1px solid #ddd; display:flex; align-items:center;}
.searchbar input {border:none; outline:none; width:100%; margin:0 5px;}
.cat-row {display:flex; justify-content:space-around; background:white; padding:10px 0; overflow-x:auto;}
.cat-row img {border-radius:50%; width:60px; height:60px;}
.cat-row p {font-size:11px; text-align:center; width:60px; margin:5px 0 0 0;}
.filterbar {display:flex; justify-content:space-around; background:white; padding:12px 0; border-top:1px solid #eee; border-bottom:1px solid #eee; font-size:14px;}
.products {display:grid; grid-template-columns:1fr 1fr; gap:5px; padding:5px;}
.card {background:white; padding:5px; position:relative;}
.card img {width:100%; border-radius:5px;}
.heart {position:absolute; top:10px; right:10px; background:white; border-radius:50%; padding:5px 8px;}
.name {font-size:13px; margin:5px 0;}
.price {font-weight:bold; font-size:16px; margin:0;}
.offer {color:green; font-size:12px; margin:0;}
.rating {background:green; color:white; display:inline-block; padding:2px 6px; border-radius:10px; font-size:11px;}
.ad {background:#eee; color:gray; font-size:10px; padding:1px 4px; display:inline;}
.refer-popup {position:fixed; bottom:80px; right:10px; width:200px; background:white; border-radius:10px; box-shadow:0 0 10px rgba(0,0,0,0.2);}
.refer-popup span {position:absolute; top:5px; right:8px; cursor:pointer;}
.bottom {position:fixed; bottom:0; width:100%; background:white; display:flex; justify-content:space-around; padding:5px 0; border-top:1px solid #ddd; font-size:10px; text-align:center;}
.bottom .active {color:purple;}