*{
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f5f5f5;
}


/* Header */

header {
    background: #ff3f6c;
    padding: 15px;
    color: white;
}

.top{
    display:flex;
    align-items:center;
    justify-content:space-between;
}

.top h2{
    margin:0;
    font-size:20px;
}

.menu,
.cart{
    background:white;
    border:none;
    border-radius:50%;
    width:40px;
    height:40px;
    font-size:20px;
}


header input {
    width:100%;
    padding:13px;
    border-radius:25px;
    border:none;
    margin-top:15px;
    font-size:15px;
}


/* Categories */

.categories {
    display:flex;
    gap:10px;
    padding:15px;
    overflow-x:auto;
}

.categories button {
    min-width:90px;
    padding:12px;
    border:none;
    border-radius:25px;
    background:white;
    font-weight:bold;
}


/* Title */

.title{
    padding-left:15px;
}


/* Products */

.products {
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:15px;
    padding:15px;
}


.card {
    background:white;
    border-radius:15px;
    padding:10px;
    box-shadow:0 2px 8px #ddd;
}


.card img {
    width:100%;
    height:170px;
    object-fit:cover;
    border-radius:12px;
}


.card h3{
    font-size:16px;
    margin:10px 0;
}


.card p{
    color:#ff3f6c;
    font-size:18px;
    font-weight:bold;
}


.card button {
    background:#ff3f6c;
    color:white;
    border:none;
    padding:12px;
    width:100%;
    border-radius:25px;
    font-size:15px;
}


/* Mobile */

@media(max-width:500px){

.products{
    grid-template-columns:repeat(2,1fr);
}

.card img{
    height:140px;
}

}