*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f5f5f5;
padding-bottom:80px;
}

header{
background:#fff;
padding:15px;
position:sticky;
top:0;
z-index:100;
box-shadow:0 2px 5px rgba(0,0,0,.1);
}

.top{
display:flex;
align-items:center;
justify-content:space-between;
gap:10px;
}

.profile{
width:40px;
height:40px;
border-radius:50%;
background:#eee;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
}

.top h2{
font-size:18px;
flex:1;
color:#8e24aa;
}

.top button{
background:#f3e5f5;
color:#8e24aa;
border:none;
padding:8px 12px;
border-radius:20px;
font-weight:bold;
}

.icons{
font-size:22px;
}

.search{
margin-top:15px;
background:#fff;
border:1px solid #ddd;
border-radius:30px;
padding:12px 18px;
color:#888;
}

.categories{
display:flex;
overflow-x:auto;
gap:15px;
padding:15px;
background:#fff;
}

.categories div{
min-width:70px;
text-align:center;
}

.categories div{
width:60px;
height:60px;
background:#e8eaf6;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
}

.categories p{
margin-top:8px;
font-size:12px;
}

.filters{
display:flex;
justify-content:space-around;
background:#fff;
padding:10px;
position:sticky;
top:90px;
z-index:99;
}

.filters button{
background:#fff;
border:1px solid #ddd;
padding:8px 12px;
border-radius:8px;
font-size:14px;
}

.products{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:10px;
padding:10px;
}

.card{
background:#fff;
border-radius:10px;
overflow:hidden;
box-shadow:0 2px 5px rgba(0,0,0,.1);
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.card h3{
font-size:15px;
padding:8px;
}

.card h2{
padding:0 8px;
color:#000;
}

.card p{
padding:8px;
color:green;
font-size:14px;
}

.card button{
width:90%;
margin:10px auto;
display:block;
background:#8e24aa;
color:#fff;
border:none;
padding:10px;
border-radius:8px;
font-size:15px;
cursor:pointer;
}

footer{
position:fixed;
bottom:0;
left:0;
right:0;
background:#fff;
display:flex;
justify-content:space-around;
padding:10px 0;
box-shadow:0 -2px 5px rgba(0,0,0,.1);
text-align:center;
font-size:13px;
}

footer div{
color:#555;
}