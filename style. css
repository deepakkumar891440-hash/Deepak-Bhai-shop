*{
box-sizing:border-box;
font-family:Arial;
}

body{
margin:0;
background:#f5f5f5;
padding-bottom:70px;
}

header{
background:#fff;
padding:10px;
position:sticky;
top:0;
z-index:10;
}

.top{
display:flex;
align-items:center;
justify-content:space-between;
}

.top h2{
font-size:20px;
}

.menu,.cart{
border:0;
background:none;
font-size:25px;
}

input{
width:100%;
padding:12px;
border-radius:25px;
border:1px solid #ddd;
margin-top:10px;
}

.categories{
display:flex;
gap:10px;
padding:10px;
overflow:auto;
}

.categories button{
border:0;
background:#fff;
padding:10px 18px;
border-radius:20px;
}

.title{
padding-left:10px;
}

.products{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:12px;
padding:10px;
}

.card{
background:white;
border-radius:15px;
padding:10px;
box-shadow:0 2px 8px #ddd;
}

.card img{
width:100%;
height:150px;
object-fit:cover;
border-radius:12px;
}

.card h3{
font-size:15px;
margin:8px 0;
}

.card p{
color:#777;
}

.card button{
width:100%;
padding:10px;
border:0;
border-radius:20px;
background:#ff3f6c;
color:white;
font-size:15px;
}

nav{
position:fixed;
bottom:0;
left:0;
right:0;
height:60px;
background:white;
display:flex;
justify-content:space-around;
align-items:center;
box-shadow:0 -2px 10px #ddd;
}

nav button{
border:0;
background:none;
font-size:13px;
}