body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f5f5f5;
}

header {
    background: #ff3f6c;
    padding: 15px;
    color: white;
    text-align: center;
}

header input {
    width: 80%;
    padding: 12px;
    border-radius: 20px;
    border: none;
    margin-top: 10px;
}

.categories {
    display: flex;
    gap: 10px;
    padding: 15px;
    justify-content: center;
}

.categories button {
    padding: 10px;
    border: none;
    border-radius: 20px;
    background: white;
}

.products {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
}

.card {
    background: white;
    width: 200px;
    padding: 15px;
    border-radius: 10px;
    text-align: center;
}

.card img {
    width: 100%;
    border-radius: 10px;
}

.card button {
    background: #ff3f6c;
    color: white;
    border: none;
    padding: 12px;
    width: 100%;
    border-radius: 5px;
}