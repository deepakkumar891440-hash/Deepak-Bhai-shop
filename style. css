body {font-family:Arial; margin:0; background:#f5f5f5;}
header {background:white; padding:10px; position:sticky; top:0;}
.search {width:95%; padding:10px; border-radius:10px; border:1px solid #ddd; margin:10px;}
.categories {display:flex; gap:15px; overflow-x:auto; padding:10px; background:white;}
.cat {text-align:center; min-width:70px;}
.cat img {width:60px; height:60px; border-radius:50%; border:2px solid #eee;}
.products {display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:10px;}
.card {background:white; border-radius:8px; padding:5px;}
.card img {width:100%; height:200px; object-fit:cover; border-radius:5px;}
.price {font-weight:bold; font-size:18px; color:#000;}
.offer {color:green; font-size:12px;}
.bottom {position:fixed; bottom:0; width:100%; background:white; display:flex; justify-content:space-around; padding:10px; border-top:1px solid #ddd;}