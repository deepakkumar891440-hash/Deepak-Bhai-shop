// Products Container
const productsContainer = document.getElementById("products");

// Order Popup
const orderPopup = document.getElementById("orderPopup");
const closePopup = document.getElementById("closePopup");

// Cart
let cart = JSON.parse(localStorage.getItem("cart")) || [];
// ===============================
// Deepak Bhai Shop
// script.js - Part 3
// ===============================

// Search
const searchInput = document.querySelector(".search input");

if(searchInput){

searchInput.addEventListener("keyup", function(){

const value = this.value.toLowerCase();

const filterProducts = products.filter((item)=>{

return item.name.toLowerCase().includes(value) ||
item.category.toLowerCase().includes(value);

});

showFilterProducts(filterProducts);

});

}

function showFilterProducts(list){

productsContainer.innerHTML="";

list.forEach((item)=>{

productsContainer.innerHTML += `

<div class="product-card">

<div class="wishlist" onclick="addWishlist(${item.id})">
❤️
</div>

<img src="${item.image}" alt="${item.name}">

<h4>${item.name}</h4>

<div class="price">

<span class="new-price">₹${item.price}</span>

<span class="old-price">₹${item.oldPrice}</span>

<span class="off">${item.discount}</span>

</div>

<div class="rating">

⭐ ${item.rating} (${item.reviews})

</div>

<div class="buttons">

<button class="cart-btn" onclick="addCart(${item.id})">

🛒 Cart

</button>

<button class="order-btn" onclick="orderNow()">

Order Now

</button>

</div>

</div>

`;

});

}

// Banner Auto Slide
const slider = document.querySelector(".slider");

let slideIndex = 0;

if(slider){

setInterval(()=>{

slideIndex++;

if(slideIndex >= slider.children.length){

slideIndex = 0;

}

slider.style.transform =
`translateX(-${slideIndex*100}%)`;

slider.style.transition = "0.5s";

},3000);

}
// ===============================
// script.js - Part 4
// ===============================

// Category Filter
const categoryItems = document.querySelectorAll(".category");

categoryItems.forEach((item)=>{

item.addEventListener("click",()=>{

const category =
item.querySelector("p").innerText;

const filter = products.filter((product)=>{

return product.category.toLowerCase() === category.toLowerCase();

});

showFilterProducts(filter);

});

});

// Home Logo Click
const logo = document.querySelector(".logo");

if(logo){

logo.addEventListener("click",()=>{

showProducts();

});

}

// Menu Button
const menuBtn = document.querySelector(".menu-btn");

if(menuBtn){

menuBtn.addEventListener("click",()=>{

alert("☰ Menu Coming Soon");

});

}

// Top Icons

document.querySelectorAll(".top-icons i").forEach((icon)=>{

icon.addEventListener("click",()=>{

alert("🚀 Feature Coming Soon");

});

});

// Page Loaded

console.log("Deepak Bhai Shop Loaded Successfully");


// Wishlist
let wishlist = JSON.parse(localStorage.getItem("wishlist")) || [];

// Render Products
function showProducts() {

productsContainer.innerHTML = "";

products.forEach((item)=>{

productsContainer.innerHTML += `

<div class="product-card">

<div class="wishlist" onclick="addWishlist(${item.id})">
❤️
</div>

<img src="${item.image}" alt="${item.name}">

<h4>${item.name}</h4>

<div class="price">

<span class="new-price">
₹${item.price}
</span>

<span class="old-price">
₹${item.oldPrice}
</span>

<span class="off">
${item.discount}
</span>

</div>

<div class="rating">
⭐ ${item.rating} (${item.reviews})
</div>

<div class="buttons">

<button
class="cart-btn"
onclick="addCart(${item.id})">

🛒 Cart

</button>

<button
class="order-btn"
onclick="orderNow()">

Order Now

</button>

</div>

</div>

`;

});

}

// Start Website
showProducts();
// ===============================
// Cart Functions
// ===============================

function addCart(id){

const product = products.find(item => item.id === id);

cart.push(product);

localStorage.setItem("cart", JSON.stringify(cart));

alert("🛒 Product Added To Cart");

}

// ===============================
// Wishlist Functions
// ===============================

function addWishlist(id){

const product = products.find(item => item.id === id);

wishlist.push(product);

localStorage.setItem("wishlist", JSON.stringify(wishlist));

alert("❤️ Added To Wishlist");

}

// ===============================
// Order Popup
// ===============================

function orderNow(){

orderPopup.style.display = "flex";

}

closePopup.addEventListener("click",()=>{

orderPopup.style.display="none";

});

// Close Popup Outside

window.addEventListener("click",(e)=>{

if(e.target===orderPopup){

orderPopup.style.display="none";

}

});
